{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nexus-blocks/advanced-heading",
	"version": "1.0.0",
	"title": "Advanced Heading",
	"category": "nexus-blocks",
	"icon": { "src": "heading", "foreground": "#7C3AED" },
	"description": "Fully styled heading with gradient text, text stroke, SVG highlight shapes, and entrance animations.",
	"keywords": ["heading", "title", "h1", "h2", "h3", "nexus"],
	"textdomain": "nexus-blocks",
	"supports": {
		"anchor": true,
		"html": false,
		"customClassName": true
	},
	"attributes": {
		"uniqueId":        { "type": "string", "default": "" },
		"content":         { "type": "string", "default": "" },
		"tag":             { "type": "string", "default": "h2" },
		"alignment":       { "type": "string", "default": "left" },
		"linkUrl":         { "type": "string", "default": "" },
		"linkTarget":      { "type": "boolean", "default": false },
		"linkNofollow":    { "type": "boolean", "default": false },
		"textColor":       { "type": "string", "default": "" },
		"enableGradient":  { "type": "boolean", "default": false },
		"gradient":        { "type": "object", "default": {} },
		"typography":      { "type": "object", "default": {} },
		"enableStroke":    { "type": "boolean", "default": false },
		"strokeWidth":     { "type": "string", "default": "1px" },
		"strokeColor":     { "type": "string", "default": "#000000" },
		"enableHighlight": { "type": "boolean", "default": false },
		"highlightText":   { "type": "string", "default": "" },
		"highlightShape":  { "type": "string", "default": "underline" },
		"highlightColor":  { "type": "string", "default": "#7C3AED" },
		"highlightStrokeWidth": { "type": "number", "default": 3 },
		"highlightAnimation":   { "type": "boolean", "default": true },
		"margin":          { "type": "object", "default": {} },
		"padding":         { "type": "object", "default": {} },
		"animation":       { "type": "object", "default": {} },
		"cssId":           { "type": "string", "default": "" },
		"cssClasses":      { "type": "string", "default": "" }
	},
	"editorScript": "file:./index.js"
}
